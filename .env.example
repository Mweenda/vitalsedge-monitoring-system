# GEMINI_API_KEY: Required for AI-powered Medical RAG Assistant (full page)
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# Google Cloud Storage Corpus (production)
# Set to true to use GCS bucket instead of local file
USE_GCS_BUCKET=false
GCS_CORPUS_BUCKET=medical-corpus
GCS_CORPUS_FILE=corpora.csv
VITE_GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:5173"

# Vertex AI Search (Medical RAG Corpus)
GCLOUD_LOCATION=global
DATA_STORE_ID=medical-corpus
# Leave empty in dev to use Vite proxy to the local backend (same origin).
VITE_API_URL=
# Optional: RAG POST path. Default /api/medical-rag/query. Set /api/rag/query to use the docs alias on the same backend.
# VITE_RAG_QUERY_PATH=/api/rag/query
FRONTEND_URL=http://localhost:5173
MOCK_MEDICAL_RAG=false

# Optional: comma-separated badges shown in the authenticated sidebar footer.
# VITE_COMPLIANCE_LABELS=HIPAA aligned,HL7 FHIR R4,ISO 27001

# Firebase Configuration (replace with your project values from Firebase console)
VITE_API_KEY=your_firebase_web_api_key
VITE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_PROJECT_ID=your-project-id
VITE_STORAGE_BUCKET=your-project.appspot.com
VITE_MESSAGING_SENDER_ID=your_sender_id
VITE_APP_ID=your_app_id
VITE_MEASUREMENT_ID=your_ga_measurement_id

# Comma-separated emails that receive ADMIN in the app (optional)
# VITE_ADMIN_EMAILS=admin@hospital.org
